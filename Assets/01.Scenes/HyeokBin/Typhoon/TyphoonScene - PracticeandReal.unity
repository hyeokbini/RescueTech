  m_Script: {fileID: 11500000, guid: 995fa847d3c7f8547b52ca8e63a22496, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  textUIList:
  - "\uBC14\uB78C\uC18C\uB9AC\uAC00 \uC2EC\uC0C1\uCE58 \uC54A\uC2B5\uB2C8\uB2E4.\nTV\uB97C
    \uD2C0\uC5B4 \uBD05\uC2DC\uB2E4."
  - "\uBC14\uB78C\uC73C\uB85C \uC778\uD574 \uCC3D\uBB38\uC774 \uAE68\uC9C0\uB294
    \uAC83\uC744 \uBC29\uC9C0\uD558\uAE30 \uC704\uD574\n\uC2DD\uD0C1 \uC704 \uD14C\uC774\uD504\uB97C
    \uC7A1\uC740 \uD6C4, \uCC3D\uBB38\uC744 \uD14C\uC774\uD504\uB85C \uBCF4\uAC15\uD569\uC2DC\uB2E4."
  - "\uD3ED\uC6B0\uB97C \uB3D9\uBC18\uD55C \uD0DC\uD48D\uC73C\uB85C \uC778\uD55C
    \uB204\uC804 \uD53C\uD574\uB97C \uB9C9\uAE30 \uC704\uD574\n\uB204\uC804 \uCC28\uB2E8\uAE30\uB97C
    \uC791\uB3D9\uC2DC\uD0A4\uC138\uC694."
  - "\uD578\uB4DC\uD3F0\uC744 \uCC59\uACA8\uC11C \uD639\uC2DC \uBAA8\uB97C \uC0C1\uD669\uC744
    \uB300\uBE44\uD574 \uC5F0\uB77D \uC218\uB2E8\uC744 \uAD6C\uBE44\uD558\uACE0\n\uD604\uC7AC
    \uC0C1\uD669\uC744 \uC9C0\uC18D\uC801\uC73C\uB85C \uD655\uC778\uD558\uC138\uC694."
  - "\uD0DC\uD48D\uC774 \uC9C0\uB098\uAC04 \uAC83 \uAC19\uC2B5\uB2C8\uB2E4. \uBC14\uAE65
    \uC0C1\uD669\uC744 \uD655\uC778\uD574 \uBD05\uC2DC\uB2E4."
  textPannel: {fileID: 1375787737}
  textObject: {fileID: 227564270}
  intervalTime: 10
