--- !u!114 &251341308
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 251341307}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 995fa847d3c7f8547b52ca8e63a22496, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  textUIList:
  - "\uD654\uC7AC\uAC00 \uBC1C\uC0DD\uD588\uC2B5\uB2C8\uB2E4. \uC9C0\uC2DC\uC5D0
    \uB530\uB77C \uB300\uD53C\uD569\uC2DC\uB2E4. \n\uC77C\uB2E8 \uC8FC\uBCC0\uC5D0
    \uBD88\uC774 \uB09C \uC0AC\uC2E4\uC744 \uC54C\uB9AC\uACE0 \uBE44\uC0C1\uBCA8\uC744
    \uC6B8\uB9BD\uC2DC\uB2E4."
  - "\uC774\uC81C \uC5F0\uB77D \uC218\uB2E8\uC744 \uCC3E\uC544 119\uC5D0 \uC2E0\uACE0\uB97C
    \uD569\uC2DC\uB2E4."
  - "\uC5F0\uAE30\uC5D0 \uB178\uCD9C\uB418\uBA74 \uC704\uD5D8\uD558\uB2C8 \uB2F4\uC694\uB098
    \uD0C0\uC62C \uB4F1\uC744 \uC774\uC6A9\uD558\uC5EC \uC785\uACFC \uCF54\uB97C
    \uAC00\uB9AC\uACE0 \uC9E7\uAC8C \uD638\uD761\uD569\uC2DC\uB2E4."
  - "\uD654\uC7AC\uB85C \uC778\uD574 \uC5D8\uB9AC\uBCA0\uC774\uD130\uB294 \uACE0\uC7A5\uC774\uB098
    \uC0AC\uACE0\uAC00 \uB0A0 \uC218 \uC788\uC5B4 \uC774\uC6A9\uD558\uC9C0 \uC54A\uACE0
    \n\uACC4\uB2E8\uC744 \uC774\uC6A9\uD558\uC5EC \uB0AE\uC740 \uC790\uC138\uB85C
    \uB300\uD53C\uD569\uC2DC\uB2E4."
  - "\uACC4\uB2E8 \uC190\uC7A1\uC774\uB098 \uBB38 \uC190\uC7A1\uC774\uB294 \uD654\uC0C1\uC758
    \uC704\uD5D8\uC774 \uC788\uC73C\uB2C8 \uC870\uC2EC\uD569\uC2DC\uB2E4."
  - "\uC800\uCE35\uC778 \uACBD\uC6B0 \uC544\uB798\uB85C \uC774\uB3D9\uD574 \uAC74\uBB3C
    \uC678\uBD80\uB85C \uB300\uD53C\uD569\uC2DC\uB2E4."
  textPannel: {fileID: 918948138}
  textObject: {fileID: 1636017256}
  intervalTime: 7
