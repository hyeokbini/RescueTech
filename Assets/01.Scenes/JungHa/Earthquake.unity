--- !u!114 &814424486
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 814424484}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 995fa847d3c7f8547b52ca8e63a22496, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  textUIList:
  - "\uC9C0\uC9C4\uC774 \uBC1C\uC0DD\uD588\uC2B5\uB2C8\uB2E4. \n\uC9C0\uC2DC\uC5D0
    \uB530\uB77C \uC548\uC804\uD558\uAC8C \uB300\uD53C\uD558\uC138\uC694."
  - "\uD53C\uD574\uB97C \uC904\uC774\uAE30 \uC704\uD574 \uC9C4\uB3D9\uC774 \uC77C\uC5B4\uB0A0
    \uB54C\uB294 \uC6C0\uC9C1\uC774\uC9C0 \uC54A\uB294 \uAC83\uC774 \uC88B\uC2B5\uB2C8\uB2E4!
    \n\uB610\uD55C \uB099\uD558\uBB3C\uB85C \uC778\uD55C \uD53C\uD574\uB97C \uC904\uC774\uAE30
    \uC704\uD574 \uB192\uC740 \uAC00\uAD6C \uADFC\uCC98\uC5D0\uB294 \uBA38\uBB3C\uC9C0
    \uC54A\uC544\uC57C \uD569\uB2C8\uB2E4. "
  - "\uBA3C\uC800 \uD479\uC2E0\uD55C \uCFE0\uC158 \uB4F1\uC758 \uBB3C\uAC74\uC744
    \uCC3E\uC544 \n\uBA38\uB9AC\uB97C \uBCF4\uD638\uD558\uC138\uC694. "
  - "\uC88B\uC2B5\uB2C8\uB2E4. \n\uAC00\uC2A4\uB204\uCD9C\uB85C \uC778\uD55C \uD654\uC7AC
    \uC704\uD5D8\uC744 \uC904\uC774\uAE30 \uC704\uD574 \n\uAC00\uC2A4 \uBC38\uBE0C\uAC00
    \uC7A0\uACA8\uC788\uB294\uC9C0 \uD655\uC778\uD558\uC138\uC694. "
  - "\uAC00\uC2A4\uBC38\uBE0C\uB97C \uC7A0\uADF8\uBA74 \uD654\uC7AC\uC758 \uAC00\uB2A5\uC131\uC744
    \uC7A0\uC7AC\uC6B8 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
  - "\uC57D\uD55C \uC9C4\uB3D9\uC774 \uACC4\uC18D \uB429\uB2C8\uB2E4. \n\uC2DD\uD0C1
    \uADFC\uCC98\uB85C \uC774\uB3D9\uD574 \uC790\uB9AC\uC5D0 \uC549\uC544 \uC2DD\uD0C1
    \uC544\uB798\uC5D0\uC11C \uBAB8\uC744 \uBCF4\uD638\uD558\uC138\uC694."
  - "\uC9C0\uC9C4\uC774 \uBA48\uCD94\uAE30 \uC804\uAE4C\uC9C0 \n\uC7A0\uC2DC \uB3D9\uC548
    \uBAB8\uC744 \uBCF4\uD638\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
  - "\uAC74\uBB3C \uD754\uB4E4\uB9BC\uC774 \uBA48\uCD98 \uAC83 \uAC19\uC2B5\uB2C8\uB2E4.\n\uAC74\uBB3C
    \uBC16\uC73C\uB85C \uB300\uD53C\uD569\uC2DC\uB2E4."
  - "\uC9C0\uC9C4\uC73C\uB85C \uC778\uD574 \uC791\uB3D9\uC774 \uC911\uB2E8\uB418\uAC70\uB098
    \uCD94\uB77D \uC704\uD5D8\uC774 \uC788\uC744 \uC218 \uC788\uC73C\uB2C8 \n\uC5D8\uB808\uBCA0\uC774\uD130\uB97C
    \uC0AC\uC6A9\uD558\uC9C0 \uC54A\uB294 \uAC83\uC774 \uC548\uC804\uD569\uB2C8\uB2E4.
    \n\uACC4\uB2E8\uC744 \uC774\uC6A9\uD558\uC138\uC694!"
  - "\uAC74\uBB3C \uBC16\uC73C\uB85C \uB300\uD53C\uB97C \uC644\uB8CC\uD588\uC2B5\uB2C8\uB2E4.
    \n\uC9C0\uC9C4\uC774 \uC9C4\uC815\uB420 \uB54C\uAE4C\uC9C0 \uC8FC\uC704\uB97C
    \uC0B4\uD53C\uBA70 \n\uC548\uC804\uD55C \uACF3\uC73C\uB85C \uC774\uB3D9\uD558\uC5EC
    \uC548\uC804\uC5D0 \uC720\uC758\uD569\uC2DC\uB2E4."
  textPannel: {fileID: 994415939}
  textObject: {fileID: 1255472779}
  intervalTime: 5
