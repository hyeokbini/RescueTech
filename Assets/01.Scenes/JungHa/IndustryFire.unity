--- !u!114 &577991886
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 577991885}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 995fa847d3c7f8547b52ca8e63a22496, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  textUIList:
  - "\uC870\uC120\uC18C\uC5D0\uC11C\uB294 \uC791\uC740 \uBD88\uD2F0 \uD558\uB098\uAC00
    \uD070 \uD654\uC7AC\uB85C \uC774\uC5B4\uC9C8 \uC218 \uC788\uC2B5\uB2C8\uB2E4.
    \n\uC9C0\uAE08\uBD80\uD130 \uC6A9\uC811 \uC791\uC5C5 \uC911 \uBC1C\uC0DD\uD560
    \uC218 \uC788\uB294 \uD654\uC7AC\uB97C \uC608\uBC29\uD558\uB294 \uBC29\uBC95\uC744
    \uD559\uC2B5\uD558\uACA0\uC2B5\uB2C8\uB2E4. \n\uD654\uBA74\uC758 \uD654\uC0B4\uD45C\uB97C
    \uB530\uB77C\uAC00\uBA70 \uC21C\uC11C\uB300\uB85C \uC9C4\uD589\uD558\uC138\uC694."
  - "\uC791\uC5C5\uC790 \uC8FC\uBCC0\uC744 \uC0B4\uD3B4\uBCF4\uC138\uC694. \n\uAC00\uC5F0\uC131
    \uBB3C\uC9C8\uC774 \uC788\uC2B5\uB2C8\uB2E4. \uBAA8\uB450 \uCE58\uC6CC \uC548\uC804\uD55C
    \uC791\uC5C5 \uACF5\uAC04\uC744 \uB9CC\uB4DC\uC138\uC694."
  - "\uC6A9\uC811\uC790 \uC8FC\uBCC0\uC5D0\uB294 \uAC00\uC5F0\uC131 \uBB3C\uC9C8\uC744
    \uB450\uC9C0 \uC54A\uB294 \uAC83\uC774 \uC88B\uC2B5\uB2C8\uB2E4.\n\uD654\uC0B4\uD45C\uB97C
    \uB530\uB77C \uB2E4\uC74C\uC73C\uB85C \uC774\uB3D9\uD558\uC138\uC694"
  - "\uC6A9\uC811 \uBD88\uD2F0\uAC00 \uBC18\uB300\uCABD\uC73C\uB85C \uD280\uACE0
    \uC788\uC2B5\uB2C8\uB2E4. \n\uBD88\uAF43 \uBC29\uC9C0 \uCEE4\uBC84\uB97C \uCC3E\uC544
    \uC54C\uB9DE\uC740 \uC704\uCE58\uC5D0 \uC124\uCE58\uD558\uC138\uC694."
  - "\uBD88\uAF43 \uBC29\uC9C0 \uCEE4\uBC84\uB294 \uBD88\uD2F0\uB85C \uC778\uD55C
    \uD654\uC7AC\uB97C \uBC29\uC9C0\uD569\uB2C8\uB2E4.\n\uD654\uC0B4\uD45C\uB97C
    \uB530\uB77C \uB2E4\uC74C\uC73C\uB85C \uC774\uB3D9\uD558\uC138\uC694"
  - "\uC774\uACF3\uC740 \uC0AC\uB78C\uB4E4\uC774 \uC624\uAC00\uB294 \uAE38\uBAA9\uC785\uB2C8\uB2E4.
    \n\uC774\uACF3\uC5D0\uC11C \uC6A9\uC811\uC744 \uD558\uB824\uBA74 \uAC10\uC2DC\uC790\uAC00
    \uD544\uC694\uD569\uB2C8\uB2E4. \uAC10\uC2DC\uC790\uB97C \uC694\uCCAD\uD558\uC138\uC694."
  - "\uC88B\uC2B5\uB2C8\uB2E4.\n\uD654\uC0B4\uD45C\uB97C \uB530\uB77C \uB2E4\uC74C\uC73C\uB85C
    \uC774\uB3D9\uD558\uC138\uC694"
  - "\uAC78\uB808\uC640 \uC758\uB958 \uAC19\uC740 \uCC9C\uC774 \uBCF4\uC785\uB2C8\uB2E4.
    \uBD88\uC774 \uC27D\uAC8C \uBD99\uC2B5\uB2C8\uB2E4. \uBAA8\uB450 \uCE58\uC6B0\uC138\uC694."
  - "\uC88B\uC2B5\uB2C8\uB2E4.\n\uD654\uC0B4\uD45C\uB97C \uB530\uB77C \uB2E4\uC74C\uC73C\uB85C
    \uC774\uB3D9\uD558\uC138\uC694"
  - "\uC606\uC5D0\uC11C \uB3C4\uC7A5 \uC791\uC5C5\uC774 \uC9C4\uD589\uB418\uACE0
    \uC788\uC2B5\uB2C8\uB2E4.\n \uC6A9\uC811\uACFC \uB3C4\uC7A5\uC740 \uB3D9\uC2DC\uC5D0
    \uD560 \uC218 \uC5C6\uC2B5\uB2C8\uB2E4. \uC791\uC5C5\uC744 \uC911\uB2E8\uD558\uB3C4\uB85D
    \uC54C\uB824\uC8FC\uC138\uC694."
  textPannel: {fileID: 1030136481}
  textObject: {fileID: 758840177}
  intervalTime: 5
